# WebAZ 环境变量模板
# 复制为 .env 并填值
# 详细说明：docs/DEPLOYMENT.md

# ─── 🔴 必设（生产部署阻塞）────────────────────────────────────────
NODE_ENV=production
# MASTER_SEED 必设（不设则 boot 拒退 + 默认 seed = 任何人可推私钥）
# 生成：openssl rand -hex 32
WALLET_MASTER_SEED=
PORT=3000

# WebAuthn（生物识别 / Passkey 提现 gate 必需）
WEBAUTHN_RP_ID=yourdomain.com
WEBAUTHN_ORIGIN=https://yourdomain.com
WEBAUTHN_RP_NAME=WebAZ

# ─── 🟡 强烈建议（钱包功能依赖）───────────────────────────────────
NETWORK=base-sepolia
USDC_CONTRACT=0x036CbD53842c5426634e7929541eC2318f3dCF7e
BASE_RPC_URL=https://sepolia.base.org

# ─── 🟢 可选（按需启用）──────────────────────────────────────────
# AI 智能下单 / claim verifier 用
ANTHROPIC_API_KEY=

# Web Push 通知（VAPID key pair）
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# 慈善匿名 seed（不设则 fallback 到 WALLET_MASTER_SEED）
CHARITY_ANON_SEED=

BOOTSTRAP_ADMIN_NAME=admin

# 协议参数微调
ARB_STAKE_REQUIRED=100
VERIFIER_STAKE_REQUIRED=50

# 客户端配置（PWA 前端 build 时读）
WEBAZ_API_URL=https://yourdomain.com/api
WEBAZ_PWA_API_BASE=/api

# 内部安全（可选）
HOT_WALLET_KMS_ACK=
ADMIN_KEY=

# Agent Gateway DPoP（默认关闭；启用前须先执行 db/agent-gateway-replay.pg.sql）
WEBAZ_AGENT_GATEWAY_DPOP_TOKEN=0
WEBAZ_AGENT_GATEWAY_REPLAY_BACKEND=
WEBAZ_AGENT_GATEWAY_REPLAY_DATABASE_URL=
# 生产必填：PostgreSQL 服务端证书 CA bundle 的 base64；禁止 rejectUnauthorized=false
WEBAZ_AGENT_GATEWAY_REPLAY_TLS_CA_B64=

# 遥测（false 推荐 — 用内置 error_log）
WEBAZ_TELEMETRY=false
WEBAZ_TELEMETRY_URL=
