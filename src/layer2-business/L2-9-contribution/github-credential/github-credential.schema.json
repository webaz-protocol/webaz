{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "credential_id": {
      "type": "string",
      "minLength": 1
    },
    "event_source": {
      "type": "string",
      "const": "github_api"
    },
    "accountable_party_ref": {
      "type": "null"
    },
    "core": {
      "type": "object",
      "properties": {
        "credential_type": {
          "type": "string",
          "const": "github_contribution_credential"
        },
        "credential_version": {
          "type": "string",
          "const": "2"
        },
        "repository_id": {
          "type": "string",
          "minLength": 1
        },
        "pr_node_id": {
          "type": "string",
          "minLength": 1
        },
        "pr_number": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "base_ref": {
          "type": "string",
          "minLength": 1
        },
        "head_sha": {
          "type": "string",
          "minLength": 1
        },
        "merge_commit_sha": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "merged_at": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "github_actor_id": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle_event": {
          "type": "string",
          "enum": [
            "merged"
          ]
        },
        "supersedes_credential_id": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "credential_type",
        "credential_version",
        "repository_id",
        "pr_node_id",
        "pr_number",
        "base_ref",
        "head_sha",
        "merge_commit_sha",
        "merged_at",
        "github_actor_id",
        "lifecycle_event",
        "supersedes_credential_id"
      ],
      "additionalProperties": false
    },
    "core_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "observation": {
      "type": "object",
      "properties": {
        "observed_at": {
          "type": "string",
          "minLength": 1
        },
        "repository_owner": {
          "type": "string",
          "minLength": 1
        },
        "repository_name": {
          "type": "string",
          "minLength": 1
        },
        "repository_visibility_at_observation": {
          "type": "string",
          "enum": [
            "public",
            "private",
            "internal",
            "unknown"
          ]
        },
        "head_ref": {
          "type": "string",
          "minLength": 1
        },
        "github_login": {
          "type": "string",
          "minLength": 1
        },
        "commit_authors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "author_id": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "login": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "name": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "is_coauthor": {
                "type": "boolean"
              }
            },
            "required": [
              "author_id",
              "login",
              "name",
              "is_coauthor"
            ],
            "additionalProperties": false
          }
        },
        "agent_provenance": {
          "type": "string",
          "enum": [
            "human",
            "ai_assisted",
            "ai_authored",
            "unknown"
          ]
        },
        "claimed_task_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "source_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "contribution_type": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "code",
                "tests",
                "audit",
                "maintenance",
                "governance",
                "usage",
                "transaction",
                "referral"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "verification_state": {
          "type": "string",
          "enum": [
            "verified",
            "unverified",
            "insufficient_evidence"
          ]
        },
        "evidence_scope": {
          "type": "string",
          "enum": [
            "public_metadata",
            "repo_collaborator_metadata"
          ]
        },
        "checks_summary": {
          "type": "object",
          "properties": {
            "total": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "success": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "failure": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "neutral": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "other": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "total",
            "success",
            "failure",
            "neutral",
            "other"
          ],
          "additionalProperties": false
        },
        "reviews_summary": {
          "type": "object",
          "properties": {
            "approved": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "changes_requested": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "commented": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "reviewer_ids": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "approved",
            "changes_requested",
            "commented",
            "reviewer_ids"
          ],
          "additionalProperties": false
        },
        "dco_state": {
          "type": "string",
          "enum": [
            "present",
            "absent",
            "unknown"
          ]
        },
        "evidence_coverage": {
          "type": "object",
          "properties": {
            "checks": {
              "type": "string",
              "enum": [
                "observed",
                "unobserved",
                "partial"
              ]
            },
            "reviews": {
              "type": "string",
              "enum": [
                "observed",
                "unobserved",
                "partial"
              ]
            },
            "commit_authors": {
              "type": "string",
              "enum": [
                "observed",
                "unobserved",
                "partial"
              ]
            },
            "dco": {
              "type": "string",
              "enum": [
                "observed",
                "unobserved"
              ]
            }
          },
          "required": [
            "checks",
            "reviews",
            "commit_authors",
            "dco"
          ],
          "additionalProperties": false
        },
        "merged_by_actor_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "known_limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "observed_at",
        "repository_owner",
        "repository_name",
        "repository_visibility_at_observation",
        "head_ref",
        "github_login",
        "commit_authors",
        "agent_provenance",
        "claimed_task_id",
        "source_ref",
        "contribution_type",
        "verification_state",
        "evidence_scope",
        "checks_summary",
        "reviews_summary",
        "dco_state",
        "evidence_coverage",
        "merged_by_actor_id",
        "evidence_refs",
        "known_limitations"
      ],
      "additionalProperties": false
    },
    "observation_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "required": [
    "credential_id",
    "event_source",
    "accountable_party_ref",
    "core",
    "core_digest",
    "observation",
    "observation_digest"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "core": {
            "properties": {
              "lifecycle_event": {
                "const": "merged"
              }
            },
            "required": [
              "lifecycle_event"
            ]
          }
        },
        "required": [
          "core"
        ]
      },
      "then": {
        "properties": {
          "core": {
            "properties": {
              "merge_commit_sha": {
                "type": "string"
              },
              "merged_at": {
                "type": "string"
              },
              "supersedes_credential_id": {
                "type": "null"
              }
            },
            "required": [
              "merge_commit_sha",
              "merged_at",
              "supersedes_credential_id"
            ]
          },
          "observation": {
            "properties": {
              "verification_state": {
                "const": "verified"
              }
            },
            "required": [
              "verification_state"
            ]
          }
        },
        "required": [
          "core",
          "observation"
        ]
      }
    }
  ]
}
